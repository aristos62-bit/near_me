rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────
    // Helper functions
    // ─────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isParticipant(chatData) {
      return request.auth.uid in chatData.participants;
    }

    function notBanned() {
      return !exists(/databases/$(database)/documents/banned/$(request.auth.uid));
    }

    function isNotBlockedInChat(chatId) {
      let chatData = get(/databases/$(database)/documents/chats/$(chatId)).data;
      let otherUid = chatData.participants[0] == request.auth.uid
        ? chatData.participants[1]
        : chatData.participants[0];
      return !exists(/databases/$(database)/documents/users/$(otherUid)/blocked/$(request.auth.uid));
    }

    function isGroupChatRef(chatId) {
      let chatData = get(/databases/$(database)/documents/chats/$(chatId)).data;
      return chatData != null && chatData.isGroupChat == true;
    }

    function isGroupCreator(chatId) {
      let chatData = get(/databases/$(database)/documents/chats/$(chatId)).data;
      return chatData != null && chatData.createdBy == request.auth.uid;
    }

    function isGroupAdmin(chatId) {
      let chatData = get(/databases/$(database)/documents/chats/$(chatId)).data;
      return chatData != null && (chatData.createdBy == request.auth.uid
        || (chatData.roles != null && chatData.roles[request.auth.uid] == 'admin'));
    }

    function isNotBlockedByTarget(toUid) {
      return !exists(/databases/$(database)/documents/users/$(toUid)/blocked/$(request.auth.uid));
    }

    function isVerified() {
      return request.auth.token.email_verified == true
          || request.auth.token.phone_number != null;
    }

    function targetCommAllowed(toUid, type) {
      let profile = get(/databases/$(database)/documents/users/$(toUid)/public/profile);
      return profile.data.isVisible == true
          && (type != 'chat' || profile.data.allowDirectChat == true)
          && (type != 'video' || profile.data.allowVideoCall == true);
    }

    // ─────────────────────────────────────────────────────────
    // Users collection
    // ─────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read, write: if false;

      match /public/{doc} {
        allow read: if isAuthenticated()
                    && notBanned()
                    && (isOwner(uid) || resource.data.isVisible == true);
        allow write: if isOwner(uid) && notBanned();
      }

      match /status/{doc} {
        allow read: if isAuthenticated();
        allow write: if isOwner(uid);
      }

      match /blocked/{blockedUid} {
        allow read: if isOwner(uid) || request.auth.uid == blockedUid;
        allow write: if isOwner(uid);
      }

      match /fcm_tokens/{tokenId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ─────────────────────────────────────────────────────────
    // Chats
    // ─────────────────────────────────────────────────────────

    match /chats/{chatId} {
      allow read: if isAuthenticated()
                  && isParticipant(resource.data);
      allow create: if isAuthenticated()
                    && isVerified()
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.participants.size() >= 2;
      allow update: if isAuthenticated()
                    && isParticipant(resource.data);
      allow delete: if isAuthenticated()
                    && isParticipant(resource.data);

      match /messages/{msgId} {
        allow read: if isAuthenticated()
                    && isParticipant(
                         get(/databases/$(database)/documents/chats/$(chatId)).data
                       );
        allow create: if isAuthenticated()
                      && isVerified()
                      && request.auth.uid == request.resource.data.senderId
                      && isParticipant(
                           get(/databases/$(database)/documents/chats/$(chatId)).data
                         )
                      && (isGroupChatRef(chatId) || isNotBlockedInChat(chatId));
        allow update: if isAuthenticated()
                      && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['isRead']);
        allow delete: if isAuthenticated()
                      && isParticipant(
                           get(/databases/$(database)/documents/chats/$(chatId)).data
                         );
      }
    }

    // ─────────────────────────────────────────────────────────
    // Requests
    // ─────────────────────────────────────────────────────────

      match /requests/{reqId} {
        allow read: if isAuthenticated()
                    && (request.auth.uid == resource.data.fromUid
                     || request.auth.uid == resource.data.toUid);
        allow create: if isAuthenticated()
                      && isVerified()
                      && request.auth.uid == request.resource.data.fromUid
                      && targetCommAllowed(request.resource.data.toUid, request.resource.data.type)
                      && notBanned()
                      && isNotBlockedByTarget(request.resource.data.toUid);
        allow update: if isAuthenticated()
                      && request.auth.uid == resource.data.toUid
                      && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['status', 'chatId', 'respondedAt', 'readAt']);
        allow delete: if isAuthenticated()
                      && (request.auth.uid == resource.data.fromUid
                       || request.auth.uid == resource.data.toUid);
      }

    // ─────────────────────────────────────────────────────────
    // Group audit log (subcollection of chats)
    // ─────────────────────────────────────────────────────────

    match /chats/{chatId}/audit_log/{logId} {
      allow read: if isAuthenticated()
                  && isParticipant(
                       get(/databases/$(database)/documents/chats/$(chatId)).data
                     );
      allow create: if isAuthenticated()
                    && isVerified()
                    && isParticipant(
                         get(/databases/$(database)/documents/chats/$(chatId)).data
                       );
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────
    // Invites (subcollection of chats)
    // ─────────────────────────────────────────────────────────

    match /chats/{chatId}/invites/{inviteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && isVerified()
                    && isParticipant(
                         get(/databases/$(database)/documents/chats/$(chatId)).data
                       );
      allow update: if isAuthenticated()
                    && (isParticipant(
                          get(/databases/$(database)/documents/chats/$(chatId)).data
                        )
                     || request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['usedBy', 'useCount']));
      allow delete: if isAuthenticated()
                    && isParticipant(
                         get(/databases/$(database)/documents/chats/$(chatId)).data
                       );
    }

    // ─────────────────────────────────────────────────────────
    // Reports
    // ─────────────────────────────────────────────────────────

    match /reports/{reportId} {
      allow create: if isAuthenticated()
                    && request.auth.uid == request.resource.data.reporterUid;
      allow read: if false;
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────
    // Collection group: public (for collectionGroup queries)
    // ─────────────────────────────────────────────────────────

    match /{path=**}/public/{doc} {
      allow read: if isAuthenticated() && notBanned() && resource.data.isVisible == true;
    }

    // ─────────────────────────────────────────────────────────
    // Collection group: invites (for collectionGroup queries)
    // ─────────────────────────────────────────────────────────

    match /{path=**}/invites/{inviteId} {
      allow read: if isAuthenticated();
    }

    // ─────────────────────────────────────────────────────────
    // Collection group: groups (public profile search)
    // ─────────────────────────────────────────────────────────

    match /{path=**}/groups/{doc} {
      allow read: if isAuthenticated() && notBanned() && resource.data.isPublic == true;
    }

    // ─────────────────────────────────────────────────────────
    // Groups public profiles (top-level collection for search)
    // ─────────────────────────────────────────────────────────

    match /groups/{doc} {
      allow read: if isAuthenticated() && notBanned() && resource.data.isPublic == true;
      allow create: if isAuthenticated()
                    && isVerified()
                    && request.auth.uid == request.resource.data.createdBy;
      allow update: if isAuthenticated()
                    && isVerified()
                    && isGroupCreator(doc);
      allow delete: if isAuthenticated()
                    && isGroupCreator(doc);
    }

    // ─────────────────────────────────────────────────────────
    // Banned users (written only by Admin SDK / Cloud Functions)
    // ─────────────────────────────────────────────────────────

    match /banned/{uid} {
      allow read: if isAuthenticated() && isOwner(uid);
      allow write: if false;
    }
  }
}
