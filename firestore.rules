rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────
    // Helper functions
    // ─────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isParticipant(chatData) {
      return request.auth.uid in chatData.participants;
    }

    function notBanned() {
      return !exists(/databases/$(database)/documents/banned/$(request.auth.uid));
    }

    function isNotBlockedInChat(chatId) {
      let chatData = get(/databases/$(database)/documents/chats/$(chatId)).data;
      let otherUid = chatData.participants[0] == request.auth.uid
        ? chatData.participants[1]
        : chatData.participants[0];
      return !exists(/databases/$(database)/documents/users/$(otherUid)/blocked/$(request.auth.uid));
    }

    function isGroupChatRef(chatId) {
      let chatData = get(/databases/$(database)/documents/chats/$(chatId)).data;
      return chatData != null && chatData.get('isGroupChat', false) == true;
    }

    function isGroupCreator(chatId) {
      let chatData = get(/databases/$(database)/documents/chats/$(chatId)).data;
      return chatData != null && chatData.participantRoles != null
          && chatData.participantRoles[request.auth.uid] == 'creator';
    }

    function isGroupAdmin(chatId) {
      let chatData = get(/databases/$(database)/documents/chats/$(chatId)).data;
      return chatData != null && chatData.participantRoles != null
          && (chatData.participantRoles[request.auth.uid] == 'creator'
           || chatData.participantRoles[request.auth.uid] == 'admin');
    }

    function isGroupMember(groupChatId) {
      let chatData = get(/databases/$(database)/documents/chats/$(groupChatId)).data;
      return chatData != null && request.auth.uid in chatData.participants;
    }

    function isNotBlockedByTarget(toUid) {
      return !exists(/databases/$(database)/documents/users/$(toUid)/blocked/$(request.auth.uid));
    }

    function isVerified() {
      return request.auth.token.email_verified == true
          || request.auth.token.phone_number != null;
    }

    function targetCommAllowed(toUid, type) {
      let profile = get(/databases/$(database)/documents/users/$(toUid)/public/profile);
      return profile.data.isVisible == true
          && (type != 'chat' || profile.data.allowDirectChat == true)
          && (type != 'video' || profile.data.allowVideoCall == true);
    }

    // ─────────────────────────────────────────────────────────
    // Users collection
    // ─────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read, write: if false;

      match /public/{doc} {
        allow read: if isAuthenticated()
                    && notBanned()
                    && (isOwner(uid) || resource.data.isVisible == true);
        allow write: if isOwner(uid) && notBanned();
      }

      match /status/{doc} {
        allow read: if isAuthenticated();
        allow write: if isOwner(uid);
      }

      match /blocked/{blockedUid} {
        allow read: if isOwner(uid) || request.auth.uid == blockedUid;
        allow write: if isOwner(uid);
      }

      match /fcm_tokens/{tokenId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ─────────────────────────────────────────────────────────
    // Chats
    // ─────────────────────────────────────────────────────────

    match /chats/{chatId} {
      allow read: if isAuthenticated()
                  && notBanned()
                  && (isParticipant(resource.data) || resource.data.isPublic == true);
      allow create: if isAuthenticated()
                    && isVerified()
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.participants.size() >= 2
                    && request.resource.data.participants.size()
                         <= request.resource.data.maxParticipants
                    && request.resource.data.maxParticipants >= 2
                    && request.resource.data.maxParticipants <= 100;
      allow update: if isAuthenticated()
                    && notBanned()
                    && isParticipant(resource.data)
                    && (
                      // Last message metadata (any participant)
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['lastMessageAt', 'lastMessageBy', 'lastMessage',
                                  'lastMessageType', 'lastMessageSender', 'systemMessage',
                                  'unreadCount'])
                      ||
                      // Read receipts (own uid only — lastReadTimestamps.{uid})
                      (request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['lastReadTimestamps', 'unreadCount'])
                       && request.resource.data.lastReadTimestamps.diff(
                            resource.data.get('lastReadTimestamps', {})
                          ).affectedKeys().hasOnly([request.auth.uid])
                       && request.resource.data.unreadCount.diff(
                            resource.data.get('unreadCount', {})
                          ).affectedKeys().hasOnly([request.auth.uid]))
                      ||
                      // Group name & avatar (admin+)
                      (request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['groupName', 'groupAvatarUrl'])
                       && (resource.data.participantRoles[request.auth.uid] == 'creator'
                        || resource.data.participantRoles[request.auth.uid] == 'admin'))
                      ||
                      // Participant management (admin+ or self-removal)
                      (request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['participants', 'participantJoinedAt',
                                   'participantInvitedBy', 'participantIsActive',
                                   'participantNicknames'])
                       && (
                         (resource.data.participantRoles[request.auth.uid] == 'creator'
                          || resource.data.participantRoles[request.auth.uid] == 'admin')
                         ||
                         // Self-removal: user removes themselves
                         (request.auth.uid in resource.data.participants
                          && !(request.auth.uid in request.resource.data.participants))
                        ))
                      ||
                      // Self-nickname update (any participant updates only their own data)
                      (request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['participantNicknames'])
                       && request.resource.data.participantNicknames.diff(
                            resource.data.get('participantNicknames', {})
                          ).affectedKeys().hasOnly([request.auth.uid]))
                      ||
                      // Self-avatar update
                      (request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['participantAvatarUrls'])
                       && request.resource.data.participantAvatarUrls.diff(
                            resource.data.get('participantAvatarUrls', {})
                          ).affectedKeys().hasOnly([request.auth.uid]))
                      ||
                      // Both together
                      (request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['participantNicknames', 'participantAvatarUrls'])
                       && request.resource.data.participantNicknames.diff(
                            resource.data.get('participantNicknames', {})
                          ).affectedKeys().hasOnly([request.auth.uid])
                       && request.resource.data.participantAvatarUrls.diff(
                            resource.data.get('participantAvatarUrls', {})
                          ).affectedKeys().hasOnly([request.auth.uid]))
                      ||
                      // Roles, permissions, limits (creator or admin)
                      (request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['participantRoles', 'permissionOverrides', 'maxParticipants'])
                        && (resource.data.participantRoles[request.auth.uid] == 'creator'
                         || resource.data.participantRoles[request.auth.uid] == 'admin'))
                      ||
                      // Legacy chat participantPair backfill (self-healing, any participant, one-time)
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['participantPair', 'isGroupChat'])
                     );
      // 1-on-1 chat: κάθε participant μπορεί να διαγράψει
      allow delete: if isAuthenticated()
                     && notBanned()
                     && request.auth.uid in resource.data.participants
                     && resource.data.get('isGroupChat', false) != true;
      // Group chat: μόνο creator ή admin
      allow delete: if isAuthenticated()
                     && notBanned()
                     && request.auth.uid in resource.data.participants
                     && resource.data.get('isGroupChat', false) == true
                     && resource.data.participantRoles != null
                      && resource.data.participantRoles[request.auth.uid] in ['creator', 'admin'];

      // Public group self-join (non-participant can join a public group)
      allow update: if isAuthenticated()
                     && notBanned()
                     && resource.data.isPublic == true
                     && !(request.auth.uid in resource.data.participants)
                     && request.auth.uid in request.resource.data.participants
                     && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['participants', 'participantNicknames', 'participantRoles',
                                  'participantJoinedAt', 'participantIsActive']);

      match /messages/{msgId} {
        allow read: if isAuthenticated()
                    && notBanned()
                    && isParticipant(
                         get(/databases/$(database)/documents/chats/$(chatId)).data
                       );
        allow create: if isAuthenticated()
                      && notBanned()
                      && isVerified()
                      && request.auth.uid == request.resource.data.senderId
                      && isParticipant(
                           get(/databases/$(database)/documents/chats/$(chatId)).data
                         )
                      && (isGroupChatRef(chatId) || isNotBlockedInChat(chatId));
        allow update: if isAuthenticated()
                      && notBanned()
                      && (
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['isRead'])
                        ||
                        (request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['reactions'])
                         && request.resource.data.reactions.diff(
                              resource.data.get('reactions', {})
                            ).affectedKeys().hasOnly([request.auth.uid]))
                        ||
                        (request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['content', 'edited', 'editedAt'])
                         && request.auth.uid == resource.data.senderId)
                      );
        allow delete: if isAuthenticated()
                      && notBanned()
                      && isParticipant(
                           get(/databases/$(database)/documents/chats/$(chatId)).data
                         )
                      && (request.auth.uid == resource.data.senderId
                          || (isGroupChatRef(chatId) && isGroupAdmin(chatId)));
      }
    }

    // ─────────────────────────────────────────────────────────
    // Requests
    // ─────────────────────────────────────────────────────────

      match /requests/{reqId} {
        allow read: if isAuthenticated()
                    && notBanned()
                    && (request.auth.uid == resource.data.fromUid
                     || request.auth.uid == resource.data.toUid);
        allow create: if isAuthenticated()
                      && isVerified()
                      && request.auth.uid == request.resource.data.fromUid
                      && targetCommAllowed(request.resource.data.toUid, request.resource.data.type)
                      && notBanned()
                      && isNotBlockedByTarget(request.resource.data.toUid);
        allow update: if isAuthenticated()
                      && notBanned()
                      && request.auth.uid == resource.data.toUid
                      && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['status', 'chatId', 'respondedAt', 'readAt']);
        allow delete: if isAuthenticated()
                      && (request.auth.uid == resource.data.fromUid
                       || request.auth.uid == resource.data.toUid);
      }

    // ─────────────────────────────────────────────────────────
    // Group audit log (subcollection of chats)
    // ─────────────────────────────────────────────────────────

    match /chats/{chatId}/audit_log/{logId} {
      allow read: if isAuthenticated()
                  && notBanned()
                  && isParticipant(
                       get(/databases/$(database)/documents/chats/$(chatId)).data
                     );
      allow create: if isAuthenticated()
                    && notBanned()
                    && isVerified()
                    && isParticipant(
                         get(/databases/$(database)/documents/chats/$(chatId)).data
                       );
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────
    // Invites (subcollection of chats)
    // ─────────────────────────────────────────────────────────

    match /chats/{chatId}/invites/{inviteId} {
      allow read: if isAuthenticated()
                  && notBanned()
                  && isParticipant(
                       get(/databases/$(database)/documents/chats/$(chatId)).data
                     );
      allow create: if isAuthenticated()
                    && notBanned()
                    && isVerified()
                    && isParticipant(
                         get(/databases/$(database)/documents/chats/$(chatId)).data
                       );
      allow update: if isAuthenticated()
                    && notBanned()
                    && (isParticipant(
                          get(/databases/$(database)/documents/chats/$(chatId)).data
                        )
                     || request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['usedBy', 'useCount']));
      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────────
    // Reports
    // ─────────────────────────────────────────────────────────

    match /reports/{reportId} {
      allow create: if isAuthenticated()
                    && request.auth.uid == request.resource.data.reporterUid;
      allow read: if false;
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────
    // Collection group: public (for collectionGroup queries)
    // ─────────────────────────────────────────────────────────

    match /{path=**}/public/{doc} {
      allow read: if isAuthenticated() && notBanned() && resource.data.isVisible == true;
    }

    // ─────────────────────────────────────────────────────────
    // Collection group: invites (for collectionGroup queries)
    // ─────────────────────────────────────────────────────────

    match /{path=**}/invites/{inviteId} {
      allow read: if isAuthenticated() && notBanned();
    }

    // ─────────────────────────────────────────────────────────
    // Collection group: groups (public profile search)
    // ─────────────────────────────────────────────────────────

    match /{path=**}/groups/{doc} {
      allow read: if isAuthenticated() && notBanned() && resource.data.isPublic == true;
    }

    // ─────────────────────────────────────────────────────────
    // Groups public profiles (top-level collection for search)
    // ─────────────────────────────────────────────────────────

    match /groups/{doc} {
      allow read: if isAuthenticated() && notBanned() && resource.data.isPublic == true;
      allow create: if isAuthenticated()
                    && isVerified()
                    && request.auth.uid == request.resource.data.createdBy;
      allow update: if isAuthenticated()
                    && notBanned()
                    && isVerified()
                    && (
                      isGroupCreator(doc)
                      ||
                      (request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['memberCount'])
                       && isGroupMember(doc))
                    );
      allow delete: if isAuthenticated()
                    && notBanned()
                    && isGroupCreator(doc);
    }

    // ─────────────────────────────────────────────────────────
    // Banned users (written only by Admin SDK / Cloud Functions)
    // ─────────────────────────────────────────────────────────

    match /banned/{uid} {
      allow read: if isAuthenticated() && isOwner(uid);
      allow write: if false;
    }
  }
}
